---
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";

const links = [
	{ href: "/", label: "Mentorship" },
	{ href: "/about", label: "About" },
	{ href: "/testimonials", label: "Testimonials" },
];

const isActive = (href: string) => pathname === href;
---

<header>
	<nav>
		<a href="/" class="wordmark">A Clear Path</a>
		<div class="nav-links">
			{
				links.map((link) => (
					<a href={link.href} class:list={["nav-link", { active: isActive(link.href) }]}>
						{link.label}
					</a>
				))
			}
			<a href="/apply" class:list={["button", "nav-apply", { active: isActive("/apply") }]}>
				Apply
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		background: var(--cream);
		border-bottom: 1px solid var(--border);
	}
	nav {
		width: 960px;
		max-width: calc(100% - 2.5em);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5em 1em;
		padding: 1em 0;
	}
	.wordmark {
		font-family: var(--font-heading);
		font-size: 1.5em;
		color: var(--deep-green);
		text-decoration: none;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	.nav-link {
		font-family: var(--font-body);
		color: var(--deep-green);
		text-decoration: none;
		padding: 0.4em 0.2em;
		margin: 0 0.6em;
		border-bottom: 3px solid transparent;
	}
	.nav-link.active {
		border-bottom-color: var(--gold);
		font-weight: 700;
	}
	.nav-apply {
		padding-top: 0.6em;
		padding-bottom: 0.6em;
		border-bottom: 3px solid var(--gold);
	}
	.nav-apply.active {
		border-bottom-color: var(--deep-green);
	}
	@media (max-width: 600px) {
		nav {
			justify-content: center;
			text-align: center;
		}
	}
</style>
