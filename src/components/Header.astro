---
import { NAV_WORDMARK, APPLY_FORM_URL } from "../consts";

const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";

const links = [
	{ href: "/", label: "Mentorship" },
	{ href: "/about", label: "About" },
	{ href: "/testimonials", label: "Testimonials" },
	{ href: "/contact", label: "Contact" },
];

const isActive = (href: string) => pathname === href;
---

<header>
	<div class="header-inner">
		<nav>
			<a href="/" class="wordmark">{NAV_WORDMARK}</a>
			<div class="nav-right">
				<div class="nav-links">
					{
						links.map((link) => (
							<a href={link.href} class:list={["nav-link", { active: isActive(link.href) }]}>
								{link.label}
							</a>
						))
					}
				</div>
				<span class="nav-divider" aria-hidden="true"></span>
				<a
					href={APPLY_FORM_URL}
					target="_blank"
					rel="noopener noreferrer"
					class="button nav-apply"
				>
					Apply
				</a>
			</div>
		</nav>
	</div>
	<div class="header-rule" aria-hidden="true"></div>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		background: var(--cream);
	}
	.header-inner {
		border-bottom: 2px solid var(--gold);
	}
	.header-rule {
		height: 1px;
		background: var(--deep-green);
	}
	nav {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.8em 1.5em;
		padding: 1.6em 3em 1.5em 3em;
	}
	.wordmark {
		font-family: var(--font-body);
		font-style: italic;
		font-weight: 500;
		font-size: 1.45em;
		color: var(--ink);
		text-decoration: none;
		white-space: nowrap;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.4em;
	}
	.nav-links {
		display: flex;
		align-items: center;
	}
	.nav-link {
		font-family: var(--font-heading);
		font-weight: 500;
		font-size: 1.05em;
		color: var(--ink);
		text-decoration: none;
		padding: 0.4em 0.2em;
		margin: 0 0.75em;
		border-bottom: 3px solid transparent;
	}
	.nav-link:hover {
		color: var(--deep-green);
	}
	.nav-link.active {
		border-bottom-color: var(--gold);
		font-weight: 600;
		color: var(--ink);
	}
	.nav-divider {
		display: block;
		width: 1px;
		height: 1.5em;
		background: var(--border);
	}
	.nav-apply {
		font-size: 1.05em;
		padding: 0.65em 1.5em;
		border-bottom: 3px solid var(--deep-green);
	}
	.nav-apply.active {
		background: var(--deep-green);
		border-color: var(--deep-green);
		color: var(--paper);
	}
	@media (max-width: 640px) {
		nav {
			justify-content: center;
			text-align: center;
			padding-left: 1.5em;
			padding-right: 1.5em;
		}
		.nav-right {
			justify-content: center;
			flex-wrap: wrap;
		}
		.nav-links {
			flex-wrap: wrap;
			justify-content: center;
		}
		.nav-link {
			font-size: 0.92em;
			margin: 0 0.45em;
		}
		.nav-divider {
			display: none;
		}
	}
</style>
