---
const today = new Date();
const isContactPage = Astro.url.pathname.replace(/\/+$/, "") === "/contact";
---

<footer>
	<div class="footer-inner">
		<p class="wordmark">A Clear Path</p>
		{
			!isContactPage && (
				<p class="contact-link">
					<a href="/contact">Get in Touch</a>
				</p>
			)
		}
		<p class="copyright">&copy; {today.getFullYear()} A Clear Path. All rights reserved.</p>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		background: var(--cream);
	}
	.footer-inner {
		width: 1000px;
		max-width: calc(100% - 3em);
		margin: 0 auto;
		padding: 2.5em 0 3em 0;
		text-align: center;
		color: var(--deep-green);
	}
	.wordmark {
		font-family: var(--font-body);
		font-style: italic;
		font-weight: 500;
		font-size: 1.4em;
		color: var(--ink);
		margin: 0 0 0.6em 0;
	}
	.contact-link {
		margin: 0 0 0.6em 0;
		font-size: 1.15em;
	}
	.contact-link a {
		color: var(--deep-green);
	}
	.copyright {
		margin: 0;
		font-size: 0.85em;
	}
</style>
