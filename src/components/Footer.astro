---
import { CONTACT_EMAIL, CONTACT_PHONE, CONTACT_PHONE_HREF } from "../consts";
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p class="wordmark">A Clear Path</p>
		<p class="contact">
			<a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
			<span aria-hidden="true">·</span>
			<a href={`tel:+1${CONTACT_PHONE_HREF}`}>{CONTACT_PHONE}</a>
		</p>
		<p class="copyright">&copy; {today.getFullYear()} A Clear Path. All rights reserved.</p>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		background: var(--cream);
	}
	.footer-inner {
		width: 1000px;
		max-width: calc(100% - 3em);
		margin: 0 auto;
		padding: 3em 0 3.5em 0;
		text-align: center;
		color: var(--deep-green);
	}
	.wordmark {
		font-family: var(--font-body);
		font-style: italic;
		font-weight: 500;
		font-size: 1.15em;
		color: var(--ink);
		margin: 0 0 0.6em 0;
	}
	.contact {
		margin: 0 0 0.5em 0;
	}
	.contact a {
		color: var(--deep-green);
	}
	.contact span {
		margin: 0 0.5em;
		color: var(--gold);
	}
	.copyright {
		margin: 0;
		font-size: 0.85em;
	}
</style>
