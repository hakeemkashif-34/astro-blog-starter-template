---
import Layout from "../layouts/Layout.astro";
import {
	CONTACT_NAME,
	CONTACT_EMAIL,
	CONTACT_PHONE,
	CONTACT_PHONE_HREF,
	YOUTUBE_CHANNEL_URL,
	LINKEDIN_URL,
} from "../consts";

const linkedinDisplay = LINKEDIN_URL.replace(/^https?:\/\//, "").replace(/\/$/, "");
const youtubeDisplay = YOUTUBE_CHANNEL_URL.replace(/^https?:\/\//, "").replace(/\/$/, "");

const methods = [
	{ label: "Email", value: CONTACT_EMAIL, href: `mailto:${CONTACT_EMAIL}`, icon: "email" },
	{ label: "Phone", value: CONTACT_PHONE, href: `tel:+1${CONTACT_PHONE_HREF}`, icon: "phone" },
	{ label: "LinkedIn", value: linkedinDisplay, href: LINKEDIN_URL, icon: "link" },
	{ label: "YouTube", value: youtubeDisplay, href: YOUTUBE_CHANNEL_URL, icon: "play" },
];

const icons: Record<string, string> = {
	email:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="14"/><path d="M4 6.5l8 6.5 8-6.5"/></svg>',
	phone:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 3.5c1 0 2.7 2.8 2.7 3.8 0 .8-1.6 1.6-1.6 2.4 0 1.6 3.3 4.9 4.9 4.9.8 0 1.6-1.6 2.4-1.6 1 0 3.8 1.7 3.8 2.7 0 1.7-1.4 3.3-3 3.3-5 0-13-8-13-13 0-1.6 1.6-3 3.3-3z"/></svg>',
	link: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 14a4.5 4.5 0 0 0 6.4.4l2-2a4.5 4.5 0 0 0-6.4-6.4l-1.1 1.1"/><path d="M14 10a4.5 4.5 0 0 0-6.4-.4l-2 2a4.5 4.5 0 0 0 6.4 6.4l1.1-1.1"/></svg>',
	play: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="6" width="18" height="12"/><path d="M10.5 9.5v5l4.5-2.5-4.5-2.5z" fill="currentColor" stroke="none"/></svg>',
};
---

<Layout
	title={`Contact | ${CONTACT_NAME}`}
	description="Get in touch with Hakeem Kashif about A Clear Path mentoring."
>
	<section class="intro">
		<span class="eyebrow">Contact</span>
		<h1>Get in Touch</h1>
	</section>

	<section class="contact-block">
		{
			methods.map((m) => (
				<div class="item">
					<div class="item-icon" set:html={icons[m.icon]} />
					<span class="label">{m.label}</span>
					<a
						class="value"
						href={m.href}
						target={m.href.startsWith("http") ? "_blank" : undefined}
						rel={m.href.startsWith("http") ? "noopener noreferrer" : undefined}
					>
						{m.value}
					</a>
				</div>
			))
		}
	</section>

	<section class="cta">
		<a href="/apply" class="button">Apply Now</a>
	</section>
</Layout>

<style>
	.contact-block {
		border: 1px solid var(--border);
		border-top: 3px solid var(--gold);
		margin-top: 1.5em;
	}
	.item {
		display: grid;
		grid-template-columns: 1.5em 140px 1fr;
		align-items: center;
		gap: 1em;
		padding: 1.3em 1.7em;
		border-bottom: 1px solid var(--border);
	}
	.item:last-child {
		border-bottom: none;
	}
	.item-icon {
		width: 1.5em;
		height: 1.5em;
		color: var(--gold-deep);
	}
	.item-icon :global(svg) {
		width: 100%;
		height: 100%;
	}
	.label {
		font-family: var(--font-heading);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.8em;
		color: var(--gold-deep);
	}
	.value {
		font-family: var(--font-body);
		font-size: 1.2em;
		color: var(--deep-green);
		word-break: break-word;
	}
	.value:hover {
		color: var(--gold-deep);
	}
	.cta {
		text-align: center;
		padding-top: 2.5em;
		border-top: 1px solid var(--border);
		margin-top: 2.5em;
	}
	@media (max-width: 600px) {
		.item {
			grid-template-columns: 1.5em 1fr;
			grid-template-areas: "icon label" "value value";
			gap: 0.4em 1em;
		}
		.item-icon {
			grid-area: icon;
		}
		.label {
			grid-area: label;
		}
		.value {
			grid-area: value;
		}
	}
</style>
