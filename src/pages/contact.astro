---
import Layout from "../layouts/Layout.astro";
import {
	CONTACT_NAME,
	CONTACT_EMAIL,
	CONTACT_PHONE,
	CONTACT_PHONE_HREF,
	YOUTUBE_URL,
	LINKEDIN_URL,
} from "../consts";

const linkedinDisplay = LINKEDIN_URL.replace(/^https?:\/\//, "").replace(/\/$/, "");

const methods = [
	{ label: "Email", value: CONTACT_EMAIL, href: `mailto:${CONTACT_EMAIL}` },
	{ label: "Phone", value: CONTACT_PHONE, href: `tel:+1${CONTACT_PHONE_HREF}` },
	{
		label: "YouTube",
		value: "Watch This for the Sake of Allah — It Could Change Your Life FOREVER.",
		href: YOUTUBE_URL,
	},
	{ label: "LinkedIn", value: linkedinDisplay, href: LINKEDIN_URL },
];
---

<Layout
	title={`Contact | ${CONTACT_NAME}`}
	description="Get in touch with Hakeem Kashif about A Clear Path mentoring."
>
	<section class="intro">
		<span class="eyebrow">Contact</span>
		<h1>Get in Touch</h1>
		<p class="lede">Reach out through any of these. I usually get back within a day or two.</p>
	</section>

	<section class="contact-block">
		{
			methods.map((m) => (
				<div class="item">
					<span class="label">{m.label}</span>
					<a
						class="value"
						href={m.href}
						target={m.href.startsWith("http") ? "_blank" : undefined}
						rel={m.href.startsWith("http") ? "noopener noreferrer" : undefined}
					>
						{m.value}
					</a>
				</div>
			))
		}
	</section>

	<section class="cta">
		<a href="/apply" class="button">Apply Now</a>
	</section>
</Layout>

<style>
	.lede {
		font-size: 1.1em;
		max-width: 600px;
	}
	.contact-block {
		border: 1px solid var(--border);
		border-top: 3px solid var(--gold);
		margin-top: 1.5em;
	}
	.item {
		display: grid;
		grid-template-columns: 140px 1fr;
		align-items: baseline;
		gap: 1em;
		padding: 1.3em 1.7em;
		border-bottom: 1px solid var(--border);
	}
	.item:last-child {
		border-bottom: none;
	}
	.label {
		font-family: var(--font-heading);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.8em;
		color: var(--gold-deep);
	}
	.value {
		font-family: var(--font-body);
		font-size: 1.2em;
		color: var(--deep-green);
		word-break: break-word;
	}
	.value:hover {
		color: var(--gold-deep);
	}
	.cta {
		text-align: center;
		padding-top: 2.5em;
		border-top: 1px solid var(--border);
		margin-top: 2.5em;
	}
	@media (max-width: 600px) {
		.item {
			grid-template-columns: 1fr;
			gap: 0.4em;
		}
	}
</style>
