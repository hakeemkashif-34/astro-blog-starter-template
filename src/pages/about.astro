---
import Layout from "../layouts/Layout.astro";
import { CONTACT_NAME, YOUTUBE_URL } from "../consts";

const kmaPhotos = ["/kma-program-1.jpg", "/kma-program-2.jpg", "/kma-program-3.jpg"];

// Real thumbnails can't be pulled in automatically here (YouTube is
// unreachable from this environment), so each card links out with a
// styled placeholder instead of a real frame grab. Swap in real
// thumbnail images later if you want the actual YouTube previews.
const youtubeVideos = [
	{
		title: "Day in the Life of a Muslim Trying to Become Better | Ottawa 🇨🇦",
		url: "https://www.youtube.com/watch?v=wWQGASe8gv8",
		blurb:
			"A day-in-my-life video following my morning routine, made to inspire viewers to improve their own mornings, whether that's eating healthier, staying active, or building a stronger relationship with Allah SWT.",
	},
	{
		title: "Day in a Life of a Muslim High School Student",
		url: "https://www.youtube.com/watch?v=hfUdDBgYD2I",
		blurb: "A look at what a day actually looks like as a practicing Muslim in high school.",
	},
	{
		title: "Life Rules in 21 Seconds (For a Practicing Muslim)",
		url: "https://www.youtube.com/watch?v=qTNLCtbRHsk",
		blurb: "A quick set of life rules for practicing Muslims, in under 21 seconds.",
	},
	{
		title: "Watch This for the Sake of Allah — It Could Change Your Life FOREVER.",
		url: YOUTUBE_URL,
		blurb:
			"One of my first videos, and still one of the ones I'm most proud of. The comments were flooded with positive feedback.",
	},
];
---

<Layout
	title={`About | ${CONTACT_NAME}`}
	description="A short introduction to the mentor behind A Clear Path."
>
	<section class="intro">
		<div class="photo-frame">
			<img src="/about-photo.jpg" alt={CONTACT_NAME} class="photo" width="900" height="784" />
		</div>
		<div class="intro-text">
			<span class="eyebrow">About</span>
			<h1>{CONTACT_NAME}</h1>
		</div>
	</section>

	<section class="bio-section">
		<h2>Education</h2>
		<ul class="education-list">
			<li>
				<strong>University:</strong> I'm currently studying computer science at Carleton University,
				going into my 2nd year insha'Allah. Alongside school, I'm working as a software engineer
				intern at Shopify.
			</li>
			<li>
				<strong>High School:</strong> I went to Merivale High School for grades 9 and 10, where I
				was part of the International Baccalaureate program. From there, I finished grades 11 and
				12 at Earl of March.
			</li>
		</ul>
	</section>

	<section class="bio-section">
		<h2>Mentoring Experience</h2>

		<div class="sub-section">
			<h3><span class="step-num">1.</span> One-on-One Mentorship</h3>
			<p>
				My one-on-one mentoring started after parents reached out through my mom to mentor their
				kids. After the 3rd request, I decided to turn it into something formal. Since then, I've
				mentored 4 boys, ages 11 to 17, over the last 4 years, in areas like tutoring, coaching,
				sports, advice for high school transitions, and motivation for taking school seriously.
			</p>
		</div>

		<div class="sub-section">
			<h3><span class="step-num">2.</span> Course Mentorship</h3>
			<p>
				I ran the Empowering Muslim Youth program at the Kanata Muslim Association. After the
				success of a Java Boot Camp I taught, my coordinator recognized my teaching ability and
				asked me to run the program. As the course instructor, I taught 30 students essential
				skills like self-improvement, discipline, and goal-setting, tailoring lessons to
				different learning styles to help build resilience, time management, and accountability.
			</p>
			<p class="gallery-caption">From the Empowering Muslim Youth Program at KMA</p>
			<div class="gallery">
				{
					kmaPhotos.map((src) => (
						<img
							src={src}
							alt="Teaching the Empowering Muslim Youth program at the Kanata Muslim Association"
							class="gallery-photo"
						/>
					))
				}
			</div>
		</div>

		<div class="sub-section">
			<h3><span class="step-num">3.</span> External Mentorship</h3>
			<p>
				I also mentor through YouTube. I started the channel to share ideas that could genuinely
				help people and to motivate viewers to build better habits. The comments have been full
				of positive feedback, and I plan to keep making videos as another way to help young people
				improve their lives.
			</p>
			<div class="video-grid">
				{
					youtubeVideos.map((v) => (
						<a class="video-card" href={v.url} target="_blank" rel="noopener noreferrer">
							<div class="video-thumb">
								<svg class="play-icon" viewBox="0 0 24 24" aria-hidden="true">
									<circle cx="12" cy="12" r="10.5" />
									<path d="M10 8.3v7.4l6-3.7-6-3.7z" />
								</svg>
							</div>
							<div class="video-info">
								<h4>{v.title}</h4>
								<p>{v.blurb}</p>
							</div>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class="bio-section">
		<h2>Why I Mentor</h2>
		<p>
			I'm at an age where I'm still young enough to connect with kids, but old enough to have
			gone through similar experiences and offer real advice. There's a lack of mentoring
			opportunities like this, something I would have greatly benefited from at that age, and now
			I want to offer that to others.
		</p>
	</section>

	<section class="bio-section">
		<h2>Sports</h2>
		<p>
			I've completed all swimming levels, played competitive soccer 5 years ago, and played
			competitive AAA basketball a year ago. I also enjoy badminton and table tennis.
		</p>
	</section>

	<section class="cta">
		<a href="/apply" class="button">Apply Now</a>
	</section>
</Layout>

<style>
	.intro {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: 2.5em;
		align-items: center;
	}
	.photo-frame {
		width: 200px;
		height: 200px;
		border-radius: 50%;
		border: 3px solid var(--gold);
		padding: 6px;
	}
	.photo {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		object-fit: cover;
		object-position: 50% 35%;
	}
	.intro-text h1 {
		margin-top: 0.15em;
		margin-bottom: 0;
	}
	.bio-section {
		padding-top: 2.5em;
		border-top: 1px solid var(--border);
		margin-top: 2.5em;
	}
	.bio-section p:last-child {
		margin-bottom: 0;
	}
	.sub-section {
		margin-top: 1.8em;
	}
	.sub-section:first-of-type {
		margin-top: 1em;
	}
	.sub-section h3 {
		margin-bottom: 0.7em;
	}
	.step-num {
		color: var(--gold-deep);
	}
	.education-list {
		list-style: none;
		padding-left: 0;
		margin: 0;
	}
	.education-list li {
		padding-left: 1.3em;
		border-left: 2px solid var(--gold);
		margin-bottom: 1.3em;
	}
	.education-list li:last-child {
		margin-bottom: 0;
	}
	.gallery-caption {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 0.85em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--gold-deep);
		margin-bottom: 0.9em;
	}
	.gallery {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.2em;
	}
	.gallery-photo {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-top: 3px solid var(--gold);
	}
	@media (max-width: 700px) {
		.gallery {
			grid-template-columns: 1fr;
		}
	}
	.video-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.2em;
		margin-top: 1.3em;
	}
	.video-card {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--border);
		border-top: 3px solid var(--gold);
		text-decoration: none;
		color: var(--ink);
	}
	.video-card:hover {
		border-top-color: var(--gold-deep);
	}
	.video-card:hover .video-info h4 {
		color: var(--gold-deep);
	}
	.video-thumb {
		aspect-ratio: 16 / 9;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--ink);
	}
	.play-icon {
		width: 3em;
		height: 3em;
		fill: none;
		stroke: var(--gold);
		stroke-width: 1.2;
	}
	.play-icon path {
		fill: var(--gold);
		stroke: none;
	}
	.video-info {
		padding: 1.2em 1.3em;
	}
	.video-info h4 {
		margin-bottom: 0.4em;
	}
	.video-info p {
		font-size: 0.92em;
		margin-bottom: 0;
	}
	@media (max-width: 700px) {
		.video-grid {
			grid-template-columns: 1fr;
		}
	}
	.cta {
		text-align: center;
		padding-top: 2.5em;
		border-top: 1px solid var(--border);
		margin-top: 2.5em;
	}
	@media (max-width: 600px) {
		.intro {
			grid-template-columns: 1fr;
			justify-items: center;
			text-align: center;
		}
	}
</style>
