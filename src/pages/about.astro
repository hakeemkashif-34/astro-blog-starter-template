---
import Layout from "../layouts/Layout.astro";
import { CONTACT_NAME, YOUTUBE_URL } from "../consts";

const kmaPhotos = ["/kma-program-1.jpg", "/kma-program-2.jpg", "/kma-program-3.jpg"];

const eduIcons: Record<string, string> = {
	cap: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 9l10-4.5L22 9l-10 4.5L2 9z"/><path d="M6 11v5c0 1.5 2.7 3 6 3s6-1.5 6-3v-5"/><path d="M22 9v6"/></svg>',
	school:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 21V9l8-5 8 5v12"/><path d="M4 21h16"/><path d="M9 21v-6h6v6"/></svg>',
};

const mentIcons: Record<string, string> = {
	people:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="3"/><path d="M2.5 20c0-3 2.5-5.5 5.5-5.5s5.5 2.5 5.5 5.5"/><circle cx="17.5" cy="7" r="2.3"/><path d="M14.7 14.3c.8-.3 1.7-.5 2.6-.5 3 0 5.5 2.5 5.5 5.5"/></svg>',
	book: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4.5c2-1 5-1 8 0v15c-3-1-6-1-8 0z"/><path d="M20 4.5c-2-1-5-1-8 0v15c3-1 6-1 8 0z"/></svg>',
	play: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9.3"/><path d="M10 8.3v7.4l6-3.7-6-3.7z" fill="currentColor" stroke="none"/></svg>',
};

const h2Icons: Record<string, string> = {
	education:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 4h9l3 3v13H6z"/><path d="M9 9h6M9 13h6M9 17h4"/></svg>',
	experience:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="7" width="18" height="12"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>',
	heart:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20s-7-4.5-9.5-9C.5 7 2 3.5 5.5 3c2-.3 3.7.7 4.5 2 .8-1.3 2.5-2.3 4.5-2C17.9 3.5 19.5 7 21.5 11c-2.5 4.5-9.5 9-9.5 9z"/></svg>',
	star: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><path d="M12 3l2.6 5.9 6.4.6-4.8 4.3 1.4 6.3L12 16.9 6.4 20.1l1.4-6.3-4.8-4.3 6.4-.6z"/></svg>',
};

const hobbyIcons: Record<string, string> = {
	sport: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="5" r="2.3"/><path d="M9 21l1.5-6L8 12l1-4 3 1 3-1 1 4-2.5 3L15 21"/></svg>',
	flame:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3c1 3-3 4-3 7a3 3 0 0 0 6 0c0-1-1-1.5-1-2.5 1.5 1 2.5 3 2.5 5A5.5 5.5 0 1 1 8 12c0-2 1-3 1.5-4.5C10 6 11 4.5 12 3z"/></svg>',
};

// Real thumbnails can't be pulled in automatically here (YouTube is
// unreachable from this environment), so each card links out with a
// styled placeholder instead of a real frame grab. Swap in real
// thumbnail images later if you want the actual YouTube previews.
const youtubeVideos = [
	{
		title: "Day in the Life of a Muslim Trying to Become Better | Ottawa 🇨🇦",
		url: "https://www.youtube.com/watch?v=wWQGASe8gv8",
		blurb:
			"A day-in-my-life video following my morning routine, made to inspire viewers to improve their own mornings, whether that's eating healthier, staying active, or building a stronger relationship with Allah SWT.",
	},
	{
		title: "Day in a Life of a Muslim High School Student",
		url: "https://www.youtube.com/watch?v=hfUdDBgYD2I",
		blurb: "A look at what a day actually looks like as a practicing Muslim in high school.",
	},
	{
		title: "Life Rules in 21 Seconds (For a Practicing Muslim)",
		url: "https://www.youtube.com/watch?v=qTNLCtbRHsk",
		blurb: "A quick set of life rules for practicing Muslims, in under 21 seconds.",
	},
	{
		title: "Watch This for the Sake of Allah — It Could Change Your Life FOREVER.",
		url: YOUTUBE_URL,
		blurb:
			"One of my first videos, and still one of the ones I'm most proud of. The comments were flooded with positive feedback.",
	},
];
---

<Layout
	title={`About | ${CONTACT_NAME}`}
	description="A short introduction to the mentor behind A Clear Path."
>
	<section class="intro">
		<div class="photo-frame">
			<img src="/about-photo.jpg" alt={CONTACT_NAME} class="photo" width="900" height="784" />
		</div>
		<div class="intro-text">
			<span class="eyebrow">About</span>
			<h1>{CONTACT_NAME}</h1>
		</div>
	</section>

	<section class="bio-section">
		<h2><span class="h2-icon" set:html={h2Icons.education} /> Education</h2>
		<ul class="education-list">
			<li>
				<div class="edu-icon" set:html={eduIcons.cap} />
				<p>
					<strong>University:</strong> I'm currently studying computer science at Carleton
					University, going into my 2nd year insha'Allah. Alongside school, I'm working as a
					software engineer intern at Shopify.
				</p>
			</li>
			<li>
				<div class="edu-icon" set:html={eduIcons.school} />
				<p>
					<strong>High School:</strong> I went to Merivale High School for grades 9 and 10, where
					I was part of the International Baccalaureate program. From there, I finished grades 11
					and 12 at Earl of March.
				</p>
			</li>
		</ul>
	</section>

	<section class="bio-section">
		<h2><span class="h2-icon" set:html={h2Icons.experience} /> Mentoring Experience</h2>

		<div class="sub-section">
			<h3>
				<span class="sub-icon" set:html={mentIcons.people} />
				<span class="step-num">1.</span> One-on-One Mentorship
			</h3>
			<p>
				My one-on-one mentoring started after parents reached out through my mom to mentor their
				kids. After the 3rd request, I decided to turn it into something formal. Since then, I've
				mentored 4 boys, ages 11 to 17, over the last 4 years, in areas like tutoring (computer
				science, math, and more), coaching, sports, advice for high school transitions, and
				motivation for taking school seriously. I have a real passion for teaching, and it shows
				up in everything I do.
			</p>
		</div>

		<div class="sub-section">
			<h3>
				<span class="sub-icon" set:html={mentIcons.book} />
				<span class="step-num">2.</span> Course Mentorship
			</h3>
			<p>
				I ran the Empowering Muslim Youth program at the Kanata Muslim Association. After the
				success of a Java Boot Camp I taught, my coordinator recognized my teaching ability and
				asked me to run the program. As the course instructor, I taught 30 students essential
				skills like self-improvement, discipline, and goal-setting, tailoring lessons to
				different learning styles to help build resilience, time management, and accountability.
			</p>
			<p class="gallery-caption">From the Empowering Muslim Youth Program at the Kanata Muslim Association</p>
			<div class="gallery">
				{
					kmaPhotos.map((src) => (
						<img
							src={src}
							alt="Teaching the Empowering Muslim Youth program at the Kanata Muslim Association"
							class="gallery-photo"
						/>
					))
				}
			</div>
		</div>

		<div class="sub-section">
			<h3>
				<span class="sub-icon" set:html={mentIcons.play} />
				<span class="step-num">3.</span> External Mentorship
			</h3>
			<p>
				I also mentor through YouTube. I started the channel to share ideas that could genuinely
				help people and to motivate viewers to build better habits. The comments have been full
				of positive feedback, and I plan to keep making videos as another way to help young people
				improve their lives.
			</p>
			<div class="video-grid">
				{
					youtubeVideos.map((v) => (
						<a class="video-card" href={v.url} target="_blank" rel="noopener noreferrer">
							<div class="video-thumb">
								<svg class="play-icon" viewBox="0 0 24 24" aria-hidden="true">
									<circle cx="12" cy="12" r="10.5" />
									<path d="M10 8.3v7.4l6-3.7-6-3.7z" />
								</svg>
							</div>
							<div class="video-info">
								<h4>{v.title}</h4>
								<p>{v.blurb}</p>
							</div>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class="bio-section">
		<h2><span class="h2-icon" set:html={h2Icons.heart} /> Why I Mentor</h2>
		<p>
			I'm at an age where I'm still young enough to connect with kids, but old enough to have
			gone through similar experiences and offer real advice. There's a lack of mentoring
			opportunities like this, something I would have greatly benefited from at that age, and now
			I want to offer that to others.
		</p>
	</section>

	<section class="bio-section">
		<h2><span class="h2-icon" set:html={h2Icons.star} /> Hobbies</h2>
		<ul class="education-list">
			<li>
				<div class="edu-icon" set:html={hobbyIcons.sport} />
				<p>
					<strong>Sports:</strong> completed all swimming levels, played competitive soccer 5
					years ago, played competitive AAA basketball a year ago, and I enjoy badminton and table
					tennis.
				</p>
			</li>
			<li>
				<div class="edu-icon" set:html={hobbyIcons.flame} />
				<p>
					<strong>Passion:</strong> teaching. I ran a Java course for kids at the Kanata Muslim
					Association and have done math tutoring in the past as well.
				</p>
			</li>
		</ul>
	</section>
</Layout>

<style>
	.intro {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: 2.5em;
		align-items: center;
	}
	.photo-frame {
		width: 200px;
		height: 200px;
		border-radius: 50%;
		border: 3px solid var(--gold);
		padding: 6px;
	}
	.photo {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		object-fit: cover;
		object-position: 50% 35%;
	}
	.intro-text h1 {
		margin-top: 0.15em;
		margin-bottom: 0;
	}
	.bio-section {
		padding-top: 2.5em;
		border-top: 1px solid var(--border);
		margin-top: 2.5em;
	}
	h2 {
		display: flex;
		align-items: center;
		gap: 0.35em;
	}
	.h2-icon {
		flex: none;
		width: 0.8em;
		height: 0.8em;
		color: var(--gold-deep);
	}
	.h2-icon :global(svg) {
		width: 100%;
		height: 100%;
	}
	.bio-section p:last-child {
		margin-bottom: 0;
	}
	.sub-section {
		margin-top: 1.8em;
	}
	.sub-section:first-of-type {
		margin-top: 1em;
	}
	.sub-section h3 {
		display: flex;
		align-items: center;
		gap: 0.45em;
		margin-bottom: 0.7em;
	}
	.step-num {
		color: var(--gold-deep);
	}
	.sub-icon {
		flex: none;
		width: 1.15em;
		height: 1.15em;
		color: var(--gold-deep);
	}
	.sub-icon :global(svg) {
		width: 100%;
		height: 100%;
	}
	.education-list {
		list-style: none;
		padding-left: 0;
		margin: 0;
	}
	.education-list li {
		display: flex;
		gap: 1em;
		align-items: flex-start;
		padding-left: 1.3em;
		border-left: 2px solid var(--gold);
		margin-bottom: 1.3em;
	}
	.education-list li:last-child {
		margin-bottom: 0;
	}
	.education-list p {
		margin: 0;
	}
	.edu-icon {
		flex: none;
		width: 1.6em;
		height: 1.6em;
		margin-top: 0.15em;
		color: var(--gold-deep);
	}
	.edu-icon :global(svg) {
		width: 100%;
		height: 100%;
	}
	.gallery-caption {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 0.85em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--gold-deep);
		margin-bottom: 0.9em;
	}
	.gallery {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.2em;
	}
	.gallery-photo {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-top: 3px solid var(--gold);
	}
	@media (max-width: 700px) {
		.gallery {
			grid-template-columns: 1fr;
		}
	}
	.video-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.2em;
		margin-top: 1.3em;
	}
	.video-card {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--border);
		border-top: 3px solid var(--gold);
		text-decoration: none;
		color: var(--ink);
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			border-top-color 0.15s ease;
	}
	.video-card:hover {
		border-top-color: var(--gold-deep);
		transform: translateY(-3px);
		box-shadow: 0 14px 28px -12px rgba(23, 50, 42, 0.35);
	}
	.video-card:hover .video-info h4 {
		color: var(--gold-deep);
	}
	.video-thumb {
		aspect-ratio: 16 / 9;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--ink);
	}
	.play-icon {
		width: 3em;
		height: 3em;
		fill: none;
		stroke: var(--gold);
		stroke-width: 1.2;
	}
	.play-icon path {
		fill: var(--gold);
		stroke: none;
	}
	.video-info {
		padding: 1.2em 1.3em;
	}
	.video-info h4 {
		margin-bottom: 0.4em;
	}
	.video-info p {
		font-size: 0.92em;
		margin-bottom: 0;
	}
	@media (max-width: 700px) {
		.video-grid {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 600px) {
		.intro {
			grid-template-columns: 1fr;
			justify-items: center;
			text-align: center;
		}
	}
</style>
