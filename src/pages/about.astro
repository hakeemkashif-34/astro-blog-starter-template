---
import Layout from "../layouts/Layout.astro";
import { CONTACT_NAME } from "../consts";

// Replace the placeholder below with a real photo at /public/about-photo.jpg,
// then swap the .photo-placeholder div for: <img src="/about-photo.jpg" alt={CONTACT_NAME} class="photo" />
---

<Layout
	title={`About — ${CONTACT_NAME}`}
	description="A short introduction to the mentor behind A Clear Path."
>
	<section class="intro">
		<span class="eyebrow">About</span>
		<h1>{CONTACT_NAME}</h1>
		<div class="intro-grid">
			<div class="photo-placeholder" role="img" aria-label={`Photo of ${CONTACT_NAME}`}>Photo</div>
			<div class="intro-text">
				<p>
					I'm Hakeem, currently studying Computer Science at Carleton University, going into my
					second year insha'Allah, and working as a Software Engineer Intern at Shopify. I went to
					Maryville for grades 9 and 10 in the International Baccalaureate program, then Earl of
					March for grades 11 and 12.
				</p>
			</div>
		</div>
	</section>

	<section class="bio-section">
		<h2>Mentoring Experience</h2>
		<p>
			My one-on-one mentoring started after parents reached out through my mom to mentor their
			kids. After the third request, I decided to turn it into something formal. Since then, I've
			mentored four boys, ages 11 to 17, over the last four years, in areas like tutoring,
			coaching, sports, advice for high school transitions, and motivation for taking school
			seriously.
		</p>
		<p>
			I also ran the Empowering Muslim Youth program at the Kanata Muslim Association. After the
			success of a Java Boot Camp I taught, my coordinator recognized my teaching ability and
			asked me to run the program. As the course instructor, I taught 30 students essential skills
			like self-improvement, discipline, and goal-setting — tailoring lessons to different learning
			styles to help build resilience, time management, and accountability.
		</p>
	</section>

	<section class="bio-section">
		<h2>Why I Mentor</h2>
		<p>
			I'm at an age where I'm still young enough to connect with kids, but old enough to have gone
			through similar experiences and offer real advice. There's a lack of mentoring opportunities
			like this — something I would have greatly benefited from at that age, and now I want to
			offer that to others.
		</p>
	</section>

	<section class="bio-section">
		<h2>Off the Clock</h2>
		<p>
			I've completed all swimming levels, played competitive soccer five years ago, and played
			competitive AAA basketball a year ago. I also enjoy badminton and table tennis.
		</p>
	</section>

	<section class="cta">
		<a href="/apply" class="button">Apply Now</a>
	</section>
</Layout>

<style>
	.intro-grid {
		display: grid;
		grid-template-columns: 220px 1fr;
		gap: 2em;
		align-items: center;
		margin-top: 1.5em;
	}
	.photo-placeholder {
		width: 220px;
		height: 220px;
		border: 2px solid var(--deep-green);
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-heading);
		color: var(--deep-green);
		background: var(--cream);
	}
	.bio-section {
		padding-top: 2.5em;
		border-top: 1px solid var(--border);
		margin-top: 2.5em;
	}
	.cta {
		text-align: center;
		padding-top: 2.5em;
		border-top: 1px solid var(--border);
		margin-top: 2.5em;
	}
	@media (max-width: 600px) {
		.intro-grid {
			grid-template-columns: 1fr;
			justify-items: center;
			text-align: center;
		}
	}
</style>
