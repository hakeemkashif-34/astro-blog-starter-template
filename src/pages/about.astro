---
import Layout from "../layouts/Layout.astro";
import { CONTACT_NAME } from "../consts";

// Real photos from the Empowering Muslim Youth program at KMA aren't on
// hand yet. Once you have them, drop them in public/ (e.g.
// kma-program-1.jpg, kma-program-2.jpg) and swap the two .gallery-placeholder
// divs below for <img src="/kma-program-1.jpg" alt="..." class="gallery-photo" />.
---

<Layout
	title={`About | ${CONTACT_NAME}`}
	description="A short introduction to the mentor behind A Clear Path."
>
	<section class="intro">
		<div class="photo-frame">
			<img src="/about-photo.jpg" alt={CONTACT_NAME} class="photo" width="900" height="784" />
		</div>
		<div class="intro-text">
			<span class="eyebrow">About</span>
			<h1>{CONTACT_NAME}</h1>
			<p class="intro-line">
				Hi, I'm Hakeem. I mentor young Muslim men here in Kanata, and I wanted to share a bit
				about who I am before we meet.
			</p>
		</div>
	</section>

	<section class="bio-section">
		<h2>Education</h2>
		<ul class="education-list">
			<li>
				<strong>University:</strong> I'm currently studying computer science at Carleton University,
				going into my second year insha'Allah. Alongside school, I'm working as a software engineer
				intern at Shopify.
			</li>
			<li>
				<strong>High School:</strong> I went to Maryvale High School for grades nine and ten, where
				I was part of the International Baccalaureate program. From there, I finished grades eleven
				and twelve at Earl of March.
			</li>
		</ul>
	</section>

	<section class="bio-section">
		<h2>Mentoring Experience</h2>
		<p>
			My one-on-one mentoring started after parents reached out through my mom to mentor their
			kids. After the third request, I decided to turn it into something formal. Since then, I've
			mentored four boys, ages 11 to 17, over the last four years, in areas like tutoring,
			coaching, sports, advice for high school transitions, and motivation for taking school
			seriously.
		</p>
		<p>
			I also ran the Empowering Muslim Youth program at the Kanata Muslim Association. After the
			success of a Java Boot Camp I taught, my coordinator recognized my teaching ability and
			asked me to run the program. As the course instructor, I taught 30 students essential
			skills like self-improvement, discipline, and goal-setting, tailoring lessons to different
			learning styles to help build resilience, time management, and accountability.
		</p>
		<p class="gallery-caption">From the Empowering Muslim Youth Program at KMA</p>
		<div class="gallery">
			<div class="gallery-placeholder" role="img" aria-label="Photo from the Empowering Muslim Youth program at KMA">
				Photo
			</div>
			<div class="gallery-placeholder" role="img" aria-label="Photo from the Empowering Muslim Youth program at KMA">
				Photo
			</div>
		</div>
	</section>

	<section class="bio-section">
		<h2>Why I Mentor</h2>
		<p>
			I'm at an age where I'm still young enough to connect with kids, but old enough to have
			gone through similar experiences and offer real advice. There's a lack of mentoring
			opportunities like this, something I would have greatly benefited from at that age, and now
			I want to offer that to others.
		</p>
	</section>

	<section class="bio-section">
		<h2>Sports</h2>
		<p>
			I've completed all swimming levels, played competitive soccer five years ago, and played
			competitive AAA basketball a year ago. I also enjoy badminton and table tennis.
		</p>
	</section>

	<section class="cta">
		<a href="/apply" class="button">Apply Now</a>
	</section>
</Layout>

<style>
	.intro {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: 2.5em;
		align-items: center;
	}
	.photo-frame {
		width: 200px;
		height: 200px;
		border-radius: 50%;
		border: 3px solid var(--gold);
		padding: 6px;
	}
	.photo {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		object-fit: cover;
		object-position: 50% 35%;
	}
	.intro-text h1 {
		margin-top: 0.15em;
	}
	.intro-line {
		font-size: 1.1em;
		margin-bottom: 0;
	}
	.bio-section {
		padding-top: 2.5em;
		border-top: 1px solid var(--border);
		margin-top: 2.5em;
	}
	.bio-section p:last-child {
		margin-bottom: 0;
	}
	.education-list {
		list-style: none;
		padding-left: 0;
		margin: 0;
	}
	.education-list li {
		padding-left: 1.3em;
		border-left: 2px solid var(--gold);
		margin-bottom: 1.3em;
	}
	.education-list li:last-child {
		margin-bottom: 0;
	}
	.gallery-caption {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 0.85em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--gold-deep);
		margin-bottom: 0.9em;
	}
	.gallery {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.2em;
	}
	.gallery-placeholder {
		aspect-ratio: 4 / 3;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--border);
		border-top: 3px solid var(--gold);
		font-family: var(--font-heading);
		color: var(--gold-deep);
		background: var(--paper);
	}
	.gallery-photo {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
	}
	@media (max-width: 600px) {
		.gallery {
			grid-template-columns: 1fr;
		}
	}
	.cta {
		text-align: center;
		padding-top: 2.5em;
		border-top: 1px solid var(--border);
		margin-top: 2.5em;
	}
	@media (max-width: 600px) {
		.intro {
			grid-template-columns: 1fr;
			justify-items: center;
			text-align: center;
		}
	}
</style>
