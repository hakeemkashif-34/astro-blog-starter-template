---
import Layout from "../layouts/Layout.astro";
import {
	GOOGLE_FORM_EMBED_URL,
	APPLY_FORM_URL,
	CONTACT_EMAIL,
	CONTACT_PHONE,
	CONTACT_PHONE_HREF,
} from "../consts";

const formIcon =
	'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="3" width="14" height="18"/><path d="M9 3v2h6V3"/><path d="M8 10h8M8 13h8M8 16h5"/></svg>';
---

<Layout
	title="Apply | A Clear Path"
	description="Apply for one-on-one mentoring with A Clear Path. No commitment, the first meeting is free."
>
	<section class="intro">
		<span class="eyebrow">Apply</span>
		<h1>Let's Get Started</h1>
		<p class="lede">
			Applying doesn't commit you to anything. The first meeting is free, just a chance to meet,
			ask questions, and see if it's a good fit for your family.
		</p>
	</section>

	<section class="steps">
		<div class="step">
			<span class="step-number">1</span>
			<p>Fill out the short application form.</p>
		</div>
		<div class="step">
			<span class="step-number">2</span>
			<p>We'll set up a free first meeting to get to know each other.</p>
		</div>
		<div class="step">
			<span class="step-number">3</span>
			<p>If it's a good fit, we start weekly sessions.</p>
		</div>
	</section>

	<section class="form-section">
		{
			GOOGLE_FORM_EMBED_URL ? (
				<iframe
					src={GOOGLE_FORM_EMBED_URL}
					width="100%"
					height="1200"
					title="A Clear Path application form"
				>
					Loading…
				</iframe>
			) : (
				<div class="form-placeholder">
					<h2><span class="h2-icon" set:html={formIcon} /> Ready When You Are</h2>
					<p>Open the application form and fill it out whenever works for you.</p>
					<a
						href={APPLY_FORM_URL}
						target="_blank"
						rel="noopener noreferrer"
						class="button form-cta"
					>
						Open the Application Form
					</a>
					<p class="contact-alt">
						Prefer to reach out directly? <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a> or{" "}
						<a href={`tel:+1${CONTACT_PHONE_HREF}`}>{CONTACT_PHONE}</a>
					</p>
				</div>
			)
		}
	</section>
</Layout>

<style>
	.lede {
		font-size: 1.1em;
		max-width: 640px;
	}
	.steps {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5em;
		padding: 2.1em 0;
		border-top: 1px solid var(--border);
		margin-top: 1em;
	}
	.step {
		border: 1px solid var(--border);
		border-top: 3px solid var(--gold);
		padding: 1.7em 1.5em;
		text-align: center;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			border-top-color 0.15s ease;
	}
	.step:hover {
		transform: translateY(-3px);
		box-shadow: 0 14px 26px -14px rgba(23, 50, 42, 0.3);
		border-top-color: var(--gold-deep);
	}
	.step-number {
		display: block;
		font-family: var(--font-heading);
		font-size: 2em;
		color: var(--gold);
		margin-bottom: 0.3em;
	}
	.step p {
		margin: 0;
	}
	.form-section {
		padding-top: 2.1em;
		border-top: 1px solid var(--border);
		margin-top: 1em;
	}
	.form-section iframe {
		border: 1px solid var(--border);
	}
	.form-placeholder {
		border: 1px solid var(--border);
		border-top: 3px solid var(--gold);
		padding: 3em 2em;
		text-align: center;
	}
	.form-placeholder h2 {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.35em;
	}
	.h2-icon {
		flex: none;
		width: 0.8em;
		height: 0.8em;
		margin-top: -0.12em;
		color: var(--gold-deep);
	}
	.h2-icon :global(svg) {
		width: 100%;
		height: 100%;
	}
	.form-cta {
		margin-top: 1.3em;
	}
	.contact-alt {
		margin-top: 1.5em;
		font-size: 0.95em;
	}
	@media (max-width: 700px) {
		.steps {
			grid-template-columns: 1fr;
		}
	}
</style>
