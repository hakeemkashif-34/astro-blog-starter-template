---
import Layout from "../layouts/Layout.astro";
import { SITE_TITLE, SITE_DESCRIPTION, APPLY_FORM_URL } from "../consts";

const facts = [
	{ label: "Ages", value: "11–17", note: "flexible outside this range", icon: "ages" },
	{ label: "Frequency", value: "1–2 hrs / week", note: "ideally weekends", icon: "clock" },
	{ label: "Price", value: "$30 / hour", note: "first meeting free", icon: "coin" },
	{
		label: "Location",
		value: "Kanata",
		note: "at my family home, parent present",
		icon: "pin",
	},
];

const guideIllustration = `<svg viewBox="0 0 360 180" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
	<g class="guide-path">
		<line x1="20" y1="150" x2="340" y2="150" stroke-width="2"/>
		<circle cx="20" cy="150" r="3" fill="currentColor" stroke="none"/>
		<circle cx="340" cy="150" r="3" fill="currentColor" stroke="none"/>
		<path d="M235 150v-7M258 150v-7M281 150v-7" stroke-width="1.5"/>
	</g>
	<g class="guide-mentor">
		<circle cx="93" cy="53" r="15"/>
		<path d="M93 68 C91 83 91 94 93 107"/>
		<path d="M93 107 C88 121 83 136 76 150"/>
		<path d="M93 107 C97 121 101 136 106 150"/>
		<path d="M91 76 C86 87 83 97 81 105"/>
		<path d="M96 74 C116 79 136 84 154 89"/>
	</g>
	<g class="guide-mentee">
		<circle cx="172" cy="73" r="12"/>
		<path d="M172 85 C170 96 170 107 172 117"/>
		<path d="M172 117 C167 127 162 138 157 150"/>
		<path d="M172 117 C179 129 187 139 195 150"/>
		<path d="M170 90 C176 98 181 106 186 112"/>
	</g>
</svg>`;

const icons: Record<string, string> = {
	ages: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.5 3-6 7-6s7 2.5 7 6"/></svg>',
	clock:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="8.5"/><path d="M12 7v5l3.5 2"/></svg>',
	coin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="8.5"/><path d="M12 7.5v9M9.6 9.7c0-1.2 1-2 2.4-2s2.4.8 2.4 1.9c0 2.5-4.8 1.3-4.8 3.8 0 1.1 1 1.9 2.4 1.9s2.4-.7 2.4-1.9"/></svg>',
	pin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21s7-6.5 7-12a7 7 0 0 0-14 0c0 5.5 7 12 7 12z"/><circle cx="12" cy="9" r="2.3"/></svg>',
};

const h2Icons: Record<string, string> = {
	overview:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6h16M4 12h16M4 18h10"/></svg>',
	glance:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>',
	cover: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>',
	flag: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 3v18"/><path d="M5 4h11l-2.5 3.5L16 11H5"/></svg>',
};

const coverIcons: Record<string, string> = {
	crescent:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 4.5a7.5 7.5 0 1 0 4.8 13.3A9 9 0 0 1 15 4.5z"/><path d="M18.3 4l.5 1.3 1.2.5-1.2.5-.5 1.3-.5-1.3-1.2-.5 1.2-.5.5-1.3z" fill="currentColor" stroke="none"/></svg>',
	shield:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/></svg>',
	compass:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="8.5"/><path d="M15 9l-2 5-5 2 2-5 5-2z"/></svg>',
	mic: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="9.5" y="3" width="5" height="9" rx="2.5"/><path d="M6 11a6 6 0 0 0 12 0"/><path d="M12 17v3.5M9 20.5h6"/></svg>',
	signpost:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21V9"/><path d="M12 6l7 2.5-7 2.5"/><path d="M12 6L5 8.5 12 11"/></svg>',
	scale:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3v17M8 20h8"/><path d="M5 7h5M14 7h5"/><path d="M5 7l-2.5 5a2.5 2.5 0 0 0 5 0L5 7z"/><path d="M19 7l-2.5 5a2.5 2.5 0 0 0 5 0L19 7z"/></svg>',
	book: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5.5c-1.5-1-4-1.5-6-1v13c2 0 4.5.5 6 1.5V5.5z"/><path d="M12 5.5c1.5-1 4-1.5 6-1v13c-2 0-4.5.5-6 1.5V5.5z"/></svg>',
	target:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="8.5"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/></svg>',
	building:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 21V9l8-5 8 5v12"/><path d="M4 21h16"/><path d="M9 21v-6h6v6"/><path d="M9 12h.01M15 12h.01M12 9h.01"/></svg>',
	run: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="14" cy="4.5" r="1.6" fill="currentColor" stroke="none"/><path d="M10 21l1.5-5-2.5-2.5 1-4 3 2.5h3"/><path d="M12.5 14L16 12M11.5 16l-3.5 2.5"/></svg>',
	chat: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 5h16v10H9l-4 3.5V15H4V5z"/><path d="M9 9h6M9 12h4"/></svg>',
};

const covers = [
	{
		title: "Islamic Habits",
		why: "A blessing to learn at a young age. It builds a strong Islamic foundation that carries into adulthood.",
		example: "Morning and evening adhkar, duas after specific actions, authentic Sunnah practices, etc.",
		icon: "crescent",
	},
	{
		title: "Staying Muslim & Avoiding Haram",
		why: "Advice for maintaining Muslim identity in a non-Muslim environment.",
		example: "Navigating music, movies, and carefully using social media, etc.",
		icon: "shield",
	},
	{
		title: "Character, Discipline & Confidence",
		why: "These qualities shape how a young man carries himself and handles challenges.",
		example: "Setting a daily routine, staying calm under pressure, etc.",
		icon: "compass",
	},
	{
		title: "Public Speaking",
		why: "Clear communication shapes how well your ideas land, whether you're speaking to one person or a room.",
		example: "Presentation and communication skills, etc.",
		icon: "mic",
	},
	{
		title: "School Transitions",
		why: "The move from middle school to high school is a critical stage in a child's life.",
		example: "Choosing good friends, praying consistently in a non-Islamic school, etc.",
		icon: "signpost",
	},
	{
		title: "Lessons from My Life, Good and Bad",
		why: "Helps a child learn from my mistakes, follow what I did right, and stay motivated.",
		example: "Making better use of my time, not memorizing enough Qur'an, etc.",
		icon: "scale",
	},
	{
		title: "Academic Help",
		why: "Helpful study techniques, and support for subjects a child might be struggling in.",
		example: "Computer science, math, etc.",
		icon: "book",
	},
	{
		title: "Personal Goals",
		why: "Helps a child define clear, measurable goals in a structured way to track and complete them.",
		example: "Memorizing more Qur'an, getting a better grade in a course, etc.",
		icon: "target",
	},
	{
		title: "High School & Course Planning",
		why: "Early, informed planning helps a child make confident decisions about his academic path.",
		example: "What courses to take, summer school versus online classes, etc.",
		icon: "building",
	},
	{
		title: "Sports & Healthy Living",
		why: "Staying physically active builds confidence, strengthens brotherhood, and gives clarity to the mind.",
		example: "Advice on improving in sports, staying active, and eating healthy, etc.",
		icon: "run",
	},
	{
		title: "Specific Concerns",
		why: "Every child is different, so parents can share specific areas of focus.",
		example: "Open-ended.",
		icon: "chat",
	},
];
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<div class="hero-heading">
			<span class="path-line" aria-hidden="true"></span>
			<h1>A Clear Path</h1>
			<span class="path-line" aria-hidden="true"></span>
		</div>
		<p class="lede">
			Personalized 1-on-1 mentoring for young Muslim boys, ages 11-17. Grounded in Islamic
			values, character, academics, sports, and more.
		</p>
		<div class="hero-actions">
			<a href={APPLY_FORM_URL} target="_blank" rel="noopener noreferrer" class="button">Apply Now</a>
			<a href="#what-we-cover" class="button-outline">What We Cover</a>
		</div>
	</section>

	<section class="guide-illustration" aria-hidden="true">
		<span class="guide-svg" set:html={guideIllustration} />
	</section>

	<section class="overview">
		<h2><span class="h2-icon" set:html={h2Icons.overview} /> Overview</h2>
		<p>Mentorship is 1-on-1, not a class of students.</p>
		<p>
			We work through whatever matters most: Islamic habits, character and discipline,
			brotherhood, school, sports, or anything a parent wants addressed.
		</p>
		<p>
			Sessions take place at my family home in Kanata with a parent or family member present,
			and can include optional outdoor activities or mosque visits with parent consent.
		</p>
		<p>
			After every session, a voice message goes to a group chat with the parent giving a
			detailed overview of what was covered.
		</p>
	</section>

	<section class="facts">
		<h2><span class="h2-icon" set:html={h2Icons.glance} /> At a Glance</h2>
		<div class="facts-grid">
			{
				facts.map((fact) => (
					<div class="fact-card">
						<div class="fact-icon" set:html={icons[fact.icon]} />
						<p class="fact-value">{fact.value}</p>
						<p class="fact-label">{fact.label}</p>
						<p class="fact-note">{fact.note}</p>
					</div>
				))
			}
		</div>
	</section>

	<section id="what-we-cover" class="covers">
		<h2><span class="h2-icon" set:html={h2Icons.cover} /> What We Cover</h2>
		<div class="covers-grid">
			{
				covers.map((item, i) => (
					<div class="cover-card">
						<span class="cover-num">{i + 1}</span>
						<div class="cover-head">
							<span class="cover-icon" set:html={coverIcons[item.icon]} />
							<h3>{item.title}</h3>
						</div>
						<p class="cover-why">{item.why}</p>
						<p class="cover-example">{item.example}</p>
					</div>
				))
			}
		</div>
	</section>

	<section class="cta">
		<h2><span class="h2-icon" set:html={h2Icons.flag} /> Ready to Get Started?</h2>
		<p>
			The first meeting is free. It's simply a chance to meet, ask questions, and see if it's a
			good fit.
		</p>
		<a href={APPLY_FORM_URL} target="_blank" rel="noopener noreferrer" class="button">Apply Now</a>
	</section>
</Layout>

<style>
	.hero {
		text-align: center;
		padding-top: 1em;
		padding-bottom: 1.5em;
	}
	.hero-heading {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.3em;
		margin-bottom: 0.4em;
	}
	.hero h1 {
		font-size: 3.2em;
		margin-bottom: 0;
	}
	.path-line {
		flex: 1 1 auto;
		max-width: 100px;
		height: 2px;
		position: relative;
		background: linear-gradient(90deg, transparent, var(--gold) 40%, var(--gold) 60%, transparent);
	}
	.path-line::after {
		content: "";
		position: absolute;
		top: 50%;
		left: 0;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--gold);
		transform: translate(-50%, -50%);
	}
	.path-line:last-child::after {
		left: auto;
		right: 0;
		transform: translate(50%, -50%);
	}
	.lede {
		font-size: 1.18em;
		line-height: 1.55;
		max-width: 600px;
		margin: 0 auto 1.8em auto;
	}
	.hero-actions {
		display: flex;
		gap: 1em;
		justify-content: center;
		flex-wrap: wrap;
	}

	.guide-illustration {
		display: flex;
		justify-content: center;
		padding: 0 0 1.8em 0;
		border-top: none;
	}
	.guide-svg {
		width: 300px;
		max-width: 78%;
	}
	.guide-svg :global(svg) {
		display: block;
		width: 100%;
		height: auto;
	}
	.guide-svg :global(.guide-path) {
		color: var(--gold-deep);
		stroke: var(--gold-deep);
	}
	.guide-svg :global(.guide-mentee) {
		stroke: var(--gold-deep);
	}
	.guide-svg :global(.guide-mentor) {
		stroke: var(--deep-green);
	}

	section {
		padding: 2.5em 0;
		border-top: 1px solid var(--border);
	}
	.hero {
		border-top: none;
	}

	h2 {
		display: flex;
		align-items: center;
		gap: 0.35em;
	}
	.h2-icon {
		flex: none;
		width: 0.8em;
		height: 0.8em;
		margin-top: -0.12em;
		color: var(--gold-deep);
	}
	.h2-icon :global(svg) {
		width: 100%;
		height: 100%;
	}
	.cta h2 {
		justify-content: center;
	}

	.facts-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5em;
		margin-top: 1.5em;
	}
	.fact-card {
		border: 1px solid var(--border);
		border-top: 3px solid var(--gold);
		padding: 1.7em 1.2em;
		text-align: center;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			border-top-color 0.15s ease;
	}
	.fact-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 14px 26px -14px rgba(23, 50, 42, 0.3);
		border-top-color: var(--gold-deep);
	}
	.fact-icon {
		width: 2em;
		height: 2em;
		margin: 0 auto 0.7em auto;
		color: var(--gold-deep);
	}
	.fact-icon :global(svg) {
		width: 100%;
		height: 100%;
	}
	.fact-value {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 3.4em;
		font-family: var(--font-heading);
		font-size: 1.6em;
		color: var(--deep-green);
		margin: 0 0 0.3em 0;
	}
	.fact-label {
		font-weight: 700;
		text-transform: uppercase;
		font-size: 0.95em;
		letter-spacing: 0.05em;
		color: var(--gold);
		margin: 0 0 0.4em 0;
	}
	.fact-note {
		font-size: 0.9em;
		margin: 0;
	}

	.covers-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5em;
		margin-top: 1.5em;
	}
	.cover-card {
		position: relative;
		border: 1px solid var(--border);
		border-top: 3px solid var(--gold);
		padding: 1.7em;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			border-top-color 0.15s ease;
	}
	.cover-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 14px 26px -14px rgba(23, 50, 42, 0.3);
		border-top-color: var(--gold-deep);
	}
	.cover-num {
		position: absolute;
		top: 1em;
		right: 1em;
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: 1.4em;
		color: var(--gold-deep);
	}
	.cover-head {
		display: flex;
		align-items: center;
		gap: 0.5em;
		margin-bottom: 0.55em;
		padding-right: 1.5em;
	}
	.cover-head h3 {
		margin-bottom: 0;
	}
	.cover-icon {
		flex: none;
		width: 1.4em;
		height: 1.4em;
		color: var(--gold-deep);
	}
	.cover-icon :global(svg) {
		width: 100%;
		height: 100%;
	}
	.cover-why {
		margin-bottom: 0.7em;
	}
	.cover-example {
		font-style: italic;
		color: var(--deep-green);
		margin-bottom: 0;
		padding-top: 0.7em;
		border-top: 1px solid var(--border);
	}

	.cta {
		text-align: center;
		padding-bottom: 0;
	}

	@media (max-width: 800px) {
		.facts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.covers-grid {
			grid-template-columns: 1fr;
		}
		.hero h1 {
			font-size: 2.3em;
		}
		.hero-heading {
			gap: 0.7em;
		}
		.path-line {
			max-width: 36px;
		}
	}

	@media (max-width: 480px) {
		.path-line {
			display: none;
		}
	}
</style>
